# ─── Circle Programmable Wallets ───────────────────────────────────────────────
# Get your API key at https://console.circle.com
CIRCLE_API_KEY=TEST_API_KEY:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 32-byte hex string (run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
CIRCLE_ENTITY_SECRET=your_32_byte_hex_entity_secret_here

# Circle blockchain identifier — Arc Testnet
CIRCLE_BLOCKCHAIN=ARC-TESTNET

# Optional: Circle's internal UUID for the USDC token on this chain.
# If set, skips the token-discovery API call entirely (useful when Circle's
# /tokens endpoint doesn't list your chain). Leave blank to use tokenAddress instead.
CIRCLE_USDC_TOKEN_ID=

# ─── Wallets (populated by `npm run setup`) ───────────────────────────────────
CIRCLE_WALLET_SET_ID=
API_WALLET_ID=
API_WALLET_ADDRESS=
AGENT_WALLET_ID=
AGENT_WALLET_ADDRESS=

# ─── Arc Testnet ───────────────────────────────────────────────────────────────
# Arc Testnet RPC — replace with your preferred RPC endpoint
ARC_RPC_URL=https://rpc.arcscan.net
ARC_CHAIN_ID=1116

# USDC contract on Arc Testnet
USDC_CONTRACT_ADDRESS=0x3600000000000000000000000000000000000000

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
